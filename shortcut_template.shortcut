	<array/>
	<key>WFWorkflowMinimumClientVersion</key>
	<integer>900</integer>
	<key>WFWorkflowMinimumClientVersionString</key>
	<string>900</string>
	<key>WFWorkflowName</key>
	<string>楽天ROOMトラッカー</string>
	<key>WFWorkflowTypes</key>
	<array/>
	<key>WFWorkflowActions</key>
	<array>
		<dict>
			<key>WFWorkflowActionIdentifier</key>
			<string>is.workflow.actions.runjavascriptonwebpage</string>
			<key>WFWorkflowActionParameters</key>
			<dict>
				<key>UUID</key>
				<string>F47AC10B-58CC-4372-A567-0E02B2C3D479</string>
				<key>CustomOutputName</key>
				<string>JS結果</string>
				<key>WFJavaScript</key>
				<string>(function() {
  function parseNum(s) {
    return parseInt(String(s || '').replace(/[,，\s]/g, '')) || null;
  }

  const result = {
    action:    "receiveStats",
    followers: null,
    following: null,
    posts:     null,
    likes:     null,
  };

  try {
    const ud = window.__INITIAL_STATE__ &amp;&amp; window.__INITIAL_STATE__.userData;
    if (ud) {
      result.followers = parseNum(ud.followers_count || ud.follower_count || ud.followersCount);
      result.following = parseNum(ud.following_count || ud.followingCount);
      result.posts     = parseNum(ud.item_count      || ud.collect_count  || ud.itemsCount);
      result.likes     = parseNum(ud.liked_count     || ud.like_count     || ud.likesCount);
    }
  } catch(e) {}

  if (!result.followers) {
    try {
      const bodyText = document.body.innerText;
      const patterns = [
        { key: 'followers', re: /フォロワー[\s\S]{0,200}?([\d,]+)/ },
        { key: 'following', re: /(?&lt;!する)フォロー[\s\S]{0,200}?([\d,]+)/ },
        { key: 'posts',     re: /商品[\s\S]{0,100}?([\d,]+)/ },
        { key: 'likes',     re: /いいね[\s\S]{0,100}?([\d,]+)/ },
      ];
      patterns.forEach(({ key, re }) => {
        if (result[key] != null) return;
        const m = bodyText.match(re);
        if (m) result[key] = parseNum(m[1]);
      });
    } catch(e) {}
  }

  result.url = location.href;
  return JSON.stringify(result);
})();</string>
			</dict>
		</dict>
		<dict>
			<key>WFWorkflowActionIdentifier</key>
			<string>is.workflow.actions.downloadurl</string>
			<key>WFWorkflowActionParameters</key>
			<dict>
				<key>ShowHeaders</key>
				<false/>
				<key>WFURL</key>
				<string>https://script.google.com/macros/s/AKfycbyzLvVzPzT16OzGwAwYbFstGJyUqeTve1R3r-wIqbyvfdWZpPX9BeOXqdjDAS8muIoocg/exec</string>
				<key>WFHTTPMethod</key>
